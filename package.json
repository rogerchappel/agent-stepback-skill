{
  "name": "agent-stepback-skill",
  "version": "0.1.0",
  "description": "Turn agent run notes into a compact stepback checkpoint with facts, blockers, assumptions, and next safe actions.",
  "type": "module",
  "bin": {
    "agent-stepback": "./bin/agent-stepback.js"
  },
  "exports": {
    ".": "./src/index.js"
  },
  "scripts": {
    "test": "node --test",
    "check": "node scripts/check-package.js",
    "build": "node scripts/build.js",
    "smoke": "node bin/agent-stepback.js fixtures/run-notes.md --format markdown",
    "validate": "bash scripts/validate.sh",
    "release:check": "npm run check && npm test && npm run build && npm run smoke && node bin/agent-stepback.js fixtures/run-notes.md --format json --max-items 2 >/tmp/agent-stepback-smoke.json && npm run package:smoke",
    "package:smoke": "node scripts/package-smoke.js"
  },
  "keywords": [
    "agent",
    "checkpoint",
    "handoff",
    "redaction",
    "skill"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/agent-stepback-skill.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/agent-stepback-skill/issues"
  },
  "homepage": "https://github.com/rogerchappel/agent-stepback-skill#readme",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "bin",
    "docs",
    "fixtures",
    "scripts",
    "src",
    "SKILL.md",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "CODE_OF_CONDUCT.md"
  ]
}
